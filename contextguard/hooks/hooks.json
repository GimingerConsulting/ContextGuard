{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "test ! -f \"$PLUGIN_ROOT/hooks/session_start.py\" || python3 \"$PLUGIN_ROOT/hooks/session_start.py\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "test ! -f \"$PLUGIN_ROOT/hooks/user_prompt_submit.py\" || python3 \"$PLUGIN_ROOT/hooks/user_prompt_submit.py\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "test ! -f \"$PLUGIN_ROOT/hooks/pre_tool_use.py\" || python3 \"$PLUGIN_ROOT/hooks/pre_tool_use.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "test ! -f \"$PLUGIN_ROOT/hooks/post_tool_use.py\" || python3 \"$PLUGIN_ROOT/hooks/post_tool_use.py\""
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "test ! -f \"$PLUGIN_ROOT/hooks/pre_compact.py\" || python3 \"$PLUGIN_ROOT/hooks/pre_compact.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "test ! -f \"$PLUGIN_ROOT/hooks/stop.py\" || python3 \"$PLUGIN_ROOT/hooks/stop.py\""
          }
        ]
      }
    ]
  }
}
